# ─────────────────────────────────────────────────────────────────────────────
# Marketplace Chat — environment template.
# Copy to `.env` and fill in. All keys are validated at boot by src/config/index.js
# (fail fast — the process refuses to start if a required var is missing).
# ─────────────────────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
PORT=3000

# MongoDB (Managed Mongo connection string)
MONGO_URI=mongodb://localhost:27017/marketplace_chat

# Auth — JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# DO Spaces / S3 (presigned uploads — bytes never pass through Node)
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
SPACES_BUCKET=marketplace-chat-uploads
SPACES_KEY=
SPACES_SECRET=

# Repository seam — which message store implementation the container injects.
# `mongo` today; `scylla` after the §5 migration (dual-write → backfill → cutover).
MESSAGE_STORE=mongo

# CORS allowlist (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# ── LATER (leave unset at MVP) ───────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379          # socket adapter + presence + rate limits
# PUSH_FCM_CREDENTIALS=                      # FCM service-account JSON path
# PUSH_APNS_KEY=                             # APNs auth key
