# --- Databases (two-connection topology) ---
# Chat's own DB (read-write): conversations, messages, devices.
CHAT_MONGO_URI=mongodb://localhost:27017/GratisChat
# Main-site Gratis DB (READ-ONLY - use a read-only Atlas DB user in real environments).
GRATIS_MONGO_URI=mongodb://localhost:27017/Gratis

# --- Auth verifier seam ---
# dev  = trust the claimed userId from the token (SPOOFABLE - do not expose untrusted in prod)
# jwt  = verify a signed JWT issued by the main site (requires JWT_SECRET)
AUTH_MODE=dev
# Required (>=16 chars) only when AUTH_MODE=jwt.
JWT_SECRET=

# --- Message store seam ---
MESSAGE_STORE=mongo

# --- Server ---
NODE_ENV=development
PORT=3000
# Comma-separated CORS allowlist; * allows all (no credentials).
CORS_ORIGINS=*

# --- DigitalOcean Spaces / S3 (uploads - optional; /uploads/presign 503s if unset) ---
SPACES_ENDPOINT=
SPACES_REGION=us-east-1
SPACES_BUCKET=
SPACES_KEY=
SPACES_SECRET=
